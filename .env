CI_ENVIRONMENT = production

app.baseURL = 'https://adarsh-tripathi-portfolio.up.railway.app/'

# Force HTTPS (optional)
app.forceGlobalSecureRequests = true

# 👇 Read PORT from environment (Railway sets this automatically)
# This is not needed inside `.env`, but used in your start command

# Uncomment and update DB settings ONLY if you're using a DB
# (We'll configure the actual values from Railway dashboard later)
database.default.hostname = ${DB_HOST}
database.default.database = ${DB_NAME}
database.default.username = ${DB_USER}
database.default.password = ${DB_PASS}
database.default.DBDriver = MySQLi
database.default.DBPrefix =
